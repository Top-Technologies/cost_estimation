<?xml version="1.0" encoding="utf-8"?>
<!-- Developed by **Natnael yonas** -->
<odoo>
  <record id="view_feed_estimation_tree" model="ir.ui.view">
    <field name="name">feed.estimation.tree</field>
    <field name="model">feed.estimation</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="formula_id"/>
        <field name="date"/>
        <field name="total_cost_per_quintal"/>
        <field name="margin_percent" optional="show"/>
        <field name="profit_amount" optional="show"/>
        <field name="selling_price" optional="show"/>
        <field name="state"/>
      </list>
    </field>
  </record>

  <record id="view_feed_estimation_form" model="ir.ui.view">
    <field name="name">feed.estimation.form</field>
    <field name="model">feed.estimation</field>
    <field name="arch" type="xml">
      <form>
        <header>
            <!-- Compute Button -->
            <button name="action_compute"
                    type="object"
                    string="Compute"
                    class="btn-primary"
                    invisible="state != 'draft'"/>
            
            <!-- Submit Button -->
            <button name="action_submit"
                    type="object"
                    string="Submit for Approval"
                    class="btn-primary"
                    invisible="state != 'computed'"/>
            
            <!-- Approve Button -->
            <button name="action_approve"
                    type="object"
                    string="Approve"
                    class="btn-success"
                    invisible="state != 'submitted'"/>
            
            <!-- Reject Button -->
            <button name="action_reject"
                    type="object"
                    string="Reject"
                    class="btn-danger"
                    invisible="state != 'submitted'"/>
            
            <!-- Reset to Draft -->
            <button name="action_reset_to_draft"
                    type="object"
                    string="Reset to Draft"
                    class="btn-secondary"
                    invisible="state in ('draft', 'approved')"/>
            
            <field name="state" widget="statusbar" statusbar_visible="draft,computed,submitted,needs_update,approved"/>
        </header>
        <sheet>
          <group>
            <field name="name"/>
            <field name="formula_id" readonly="state == 'submitted' or state == 'approved'"/>
            <field name="config_id" readonly="state == 'submitted' or state == 'approved'"/>
            <field name="date"/>
            <field name="user_id" readonly="1"/>
            <field name="responsible_user_id" readonly="state == 'submitted' or state == 'approved'"/>
            <field name="approver_id" readonly="1"/>
            <field name="approval_date" readonly="1"/>
          </group>

          <notebook>
            <page string="Lines">
              <field name="line_ids" readonly="state == 'submitted' or state == 'approved'">
                <list editable="bottom">
                  <field name="company_currency_id" column_invisible="True"/>
                  <field name="type"/>
                  <field name="product_id"/>
                  <field name="input_kg"/>
                  <field name="price_per_kg"/>
                  <field name="total_cost" sum="Total Cost"/>
                </list>
              </field>
            </page>
            <page string="Inputs &amp; Assumptions">
              <group>
                <field name="total_quintal_daily" readonly="state == 'submitted' or state == 'approved'"/>
                <field name="annual_working_days" readonly="state == 'submitted' or state == 'approved'"/>
                <field name="monthly_working_days" readonly="state == 'submitted' or state == 'approved'"/>
                <field name="labor_salary_monthly" readonly="state == 'submitted' or state == 'approved'"/>
                <field name="machine_price" readonly="state == 'submitted' or state == 'approved'"/>
                <field name="loan_amount" readonly="state == 'submitted' or state == 'approved'"/>
                <field name="interest_rate" readonly="state == 'submitted' or state == 'approved'"/>
                <field name="last_10m_rm_total" readonly="state == 'submitted' or state == 'approved'"/>
                <field name="loading_cost_per_quintal_input" readonly="state == 'submitted' or state == 'approved'"/>
              </group>
            </page>
            <page string="Summary">
              <group>
                <field name="raw_material_total" readonly="1"/>
                <field name="fuel_total" readonly="1"/>
                <field name="packing_material_total" readonly="1"/>
                <field name="labor_cost_per_quintal" readonly="1"/>
                <field name="depreciation_per_quintal" readonly="1"/>
                <field name="interest_per_quintal" readonly="1"/>
                <field name="other_cost_per_quintal" readonly="1"/>
                <field name="monthly_loading_cost" readonly="1"/>
                <field name="daily_loading_cost" readonly="1"/>
                <field name="loading_cost_per_quintal" readonly="1"/>
                <field name="total_cost_per_quintal" readonly="1"/>
              </group>
            </page>
            <page string="Selling Margin Analysis">
              <group>
                <field name="cost_for_margin" readonly="1"/>
                <field name="margin_percent" readonly="state == 'submitted' or state == 'approved'"/>
                <field name="profit_amount" readonly="1"/>
                <field name="selling_price" readonly="1"/>
              </group>
            </page>
          </notebook>
        </sheet>
        <chatter>
            <field name="message_follower_ids"/>
            <field name="activity_ids"/>
            <field name="message_ids"/>
        </chatter>
      </form>
    </field>
  </record>

  <record id="action_feed_estimation" model="ir.actions.act_window">
    <field name="name">Estimations</field>
    <field name="res_model">feed.estimation</field>
    <field name="view_mode">list,form</field>
  </record>

  <menuitem id="menu_feed_estimation_action" name="Estimations" parent="menu_feed_estimation" action="action_feed_estimation"/>
</odoo>
